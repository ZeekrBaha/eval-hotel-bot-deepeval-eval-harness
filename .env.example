# Copy to .env and fill in. .env is gitignored — never commit real keys.

# DeepSeek = the LLM-as-judge (out-of-family vs the gpt-4o-mini SUT -> no self-preference bias).
# OpenAI-compatible API, base URL https://api.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI = runs the hotel bot system-under-test itself (gpt-4o-mini).
OPENAI_API_KEY=

# Optional overrides
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_JUDGE_MODEL=deepseek-chat
SUT_MODEL=gpt-4o-mini
